// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  user
  admin
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String    @default("/assets/profile.png")
  accounts      Account[]
  Post          Post[]
  role          Role      @default(user)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

enum PropertyFor {
  rent
  sale
}

enum PropertyType {
  residential
  commercial
}

model Image {
  id         Int      @id @default(autoincrement())
  image      String
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  postId     Int
}

model Post {
  id            Int          @id @default(autoincrement())
  property_id   String       @unique
  slug          String       @unique
  title         String       @db.VarChar(256)
  description   String       @db.VarChar(5000)
  area          Int
  bedroom       Int?
  bathroom      Int?
  thana         String
  district      String
  division      String
  location      String
  photo         String
  phoneNumber   String
  Images        Image[]
  property_for  PropertyFor
  property_type PropertyType
  pending       Boolean      @default(true)
  User          User         @relation(fields: [userId], references: [id])
  userId        String
  status        Boolean      @default(false)
  created_at    DateTime     @default(now())
  updated_at    DateTime     @updatedAt
}

model DeletedPost {
  id            Int          @id @default(autoincrement())
  post_id       Int
  property_id   String       @unique
  slug          String       @unique
  title         String       @db.VarChar(256)
  description   String       @db.VarChar(1500)
  area          Int
  photo         String       @default("/assets/no-image.jpg")
  bedroom       Int?
  bathroom      Int?
  thana         String
  district      String
  division      String
  location      String
  property_for  PropertyFor
  property_type PropertyType
  pending       Boolean
  phoneNumber   String
  // User Details
  userId        String
  name          String?
  email         String
  emailVerified DateTime?
  // User Details Ends
  status        Boolean      @default(false)
  deleted_at    DateTime     @default(now())
  created_at    DateTime
  updated_at    DateTime
}

model VerificationToken {
  id         Int      @id @default(autoincrement())
  email      String
  user_id    String
  token      String   @unique
  expires    DateTime
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([email, token])
}

model ResetPasswordToken {
  id         Int      @id @default(autoincrement())
  email      String
  user_id    String
  token      String   @unique
  expires    DateTime
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([email, token])
}

model UserInfo {
  id     Int    @id @default(autoincrement())
  status String @default("fail")

  ip                  String?
  ipv4                String?
  ipv6                String?
  screen              String?
  browser             String?
  browserVersion      String?
  browserMajorVersion Int?
  mobile              Boolean?
  url                 String?
  os                  String?
  osVersion           String?
  cookies             Boolean?

  continent   String?
  country     String?
  countryCode String?
  region      String?
  regionName  String?
  city        String?
  zip         String?
  district    String?
  lat         Float?
  lon         Float?
  timezone    String?
  isp         String?
  org         String?
  as          String?
  proxy       Boolean?
  query       String?

  userId     DateTime?
  logged_in  DateTime?
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
}
