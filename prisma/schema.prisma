generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              user     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "Account_userId_fkey")

  @@id([provider, providerAccountId])
  @@index([userId], map: "Account_userId_fkey")
}

model contactus {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(256)
  email       String   @db.VarChar(256)
  subject     String?  @db.VarChar(256)
  message     String   @db.VarChar(256)
  isRead      Boolean  @default(false)
  status      String   @default("Pending") @db.VarChar(256)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  messageTo   String?
  postId      Int?
  phoneNumber String?
  user        user?    @relation(fields: [messageTo], references: [id], onDelete: Cascade, map: "ContactUs_messageTo_fkey")
  post        post?    @relation(fields: [postId], references: [id], onDelete: Cascade, map: "ContactUs_postId_fkey")

  @@index([postId], map: "ContactUs_postId_fkey")
  @@index([messageTo], map: "ContactUs_messageTo_fkey")
}

model deletedpost {
  id               Int                        @id @default(autoincrement())
  post_id          Int
  property_id      String                     @unique(map: "DeletedPost_property_id_key")
  slug             String                     @unique(map: "DeletedPost_slug_key")
  title            String                     @db.VarChar(256)
  description      String                     @db.VarChar(2000)
  area             Int
  photo            String                     @default("/assets/no-image.jpg")
  total_floor      Int
  selling_floor    Int
  balcony          Int?
  facing           String
  parking          Boolean
  transaction_type String
  total_land_area  String?
  tags             String
  bedroom          Int?
  availableFrom    deletedpost_availableFrom?
  price            Int
  bathroom         Int?
  upazila          String
  district         String
  division         String
  negotiable       Boolean
  address          String
  property_for     deletedpost_property_for
  property_type    deletedpost_property_type
  pending          Boolean
  phoneNumber      String
  userId           String
  name             String?
  email            String
  emailVerified    DateTime?
  status           Boolean                    @default(false)
  deleted_at       DateTime                   @default(now())
  created_at       DateTime
  updated_at       DateTime                   @updatedAt
  amenities        String
}

model image {
  id         Int      @id @default(autoincrement())
  image      String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  postId     Int
  post       post     @relation(fields: [postId], references: [id], onDelete: Cascade, map: "Image_postId_fkey")

  @@index([postId], map: "Image_postId_fkey")
}

model post {
  id               Int                 @id @default(autoincrement())
  property_id      String              @unique(map: "Post_property_id_key")
  slug             String              @unique(map: "Post_slug_key")
  title            String              @db.VarChar(128)
  description      String              @db.VarChar(800)
  area             Int
  bedroom          Int?
  bathroom         Int?
  upazila          String
  district         String
  division         String
  address          String
  photo            String
  total_floor      Int
  selling_floor    Int
  balcony          Int?
  facing           String
  parking          Boolean
  transaction_type String
  total_land_area  String?
  tags             String
  phoneNumber      String
  negotiable       Boolean             @default(false)
  availableFrom    post_availableFrom?
  price            Int
  property_for     post_property_for
  property_type    post_property_type
  pending          Boolean             @default(true)
  userId           String
  status           Boolean             @default(false)
  created_at       DateTime            @default(now())
  updated_at       DateTime            @updatedAt
  amenities        String              @default(",")
  contactus        contactus[]
  image            image[]
  user             user                @relation(fields: [userId], references: [id], map: "Post_userId_fkey")

  @@index([userId], map: "Post_userId_fkey")
}

model resetpasswordtoken {
  id         Int      @id @default(autoincrement())
  email      String
  user_id    String
  token      String   @unique(map: "ResetPasswordToken_token_key")
  expires    DateTime
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([email, token], map: "ResetPasswordToken_email_token_key")
}

model user {
  id            String      @id @default(uuid())
  name          String?
  email         String      @unique(map: "User_email_key")
  emailVerified DateTime?
  password      String?
  image         String      @default("/assets/profile.png")
  role          user_role   @default(user)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  account       account[]
  contactus     contactus[]
  post          post[]
}

model userinfo {
  id                  Int       @id @default(autoincrement())
  status              String    @default("fail")
  ip                  String?
  ipv4                String?
  ipv6                String?
  screen              String?
  browser             String?
  browserVersion      String?
  browserMajorVersion Int?
  mobile              Boolean?
  url                 String?
  os                  String?
  osVersion           String?
  cookies             Boolean?
  continent           String?
  country             String?
  countryCode         String?
  region              String?
  regionName          String?
  city                String?
  zip                 String?
  district            String?
  lat                 Float?
  lon                 Float?
  timezone            String?
  isp                 String?
  org                 String?
  as                  String?
  proxy               Boolean?
  query               String?
  userId              DateTime?
  logged_in           DateTime?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt
}

model verificationtoken {
  id         Int      @id @default(autoincrement())
  email      String
  user_id    String
  token      String   @unique(map: "VerificationToken_token_key")
  expires    DateTime
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([email, token], map: "VerificationToken_email_token_key")
}

enum user_role {
  user
  admin
}

enum deletedpost_availableFrom {
  January
  February
  March
  April
  May
  June
  July
  August
  September
  October
  November
  December
}

enum post_availableFrom {
  January
  February
  March
  April
  May
  June
  July
  August
  September
  October
  November
  December
}

enum deletedpost_property_for {
  rent
  sale
}

enum post_property_for {
  rent
  sale
}

enum deletedpost_property_type {
  residential
  commercial
}

enum post_property_type {
  residential
  commercial
}
